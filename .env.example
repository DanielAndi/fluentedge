# FluentEdge local environment (FR-INF-007, NFR-SEC-001)
# Copy to .env and adjust as needed. Never commit real credentials.

# Application
APP_NAME=FluentEdge
ENVIRONMENT=local
LOG_LEVEL=INFO

# Storage backend: s3 (LocalStack) or filesystem (fallback)
STORAGE_BACKEND=s3
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localhost:4566
S3_UPLOAD_BUCKET=fluentedge-uploads
S3_DATA_BUCKET=fluentedge-data
S3_ARTIFACTS_BUCKET=fluentedge-artifacts
FILESYSTEM_STORAGE_ROOT=.local-storage

# Upload retention (hours)
UPLOAD_RETENTION_HOURS=24

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Model (set after training pipeline registers an approved model)
APPROVED_MODEL_URI=
APPROVED_MODEL_VERSION=

# Health-check URLs (host-side scripts)
API_URL=http://localhost:8000
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
LOCALSTACK_URL=http://localhost:4566

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
